.DS_Store
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Large training artifacts. The curated baseline checkpoint is force-added to
# Git LFS (see .gitattributes); this rule only keeps *new* run outputs from
# being committed by accident.
outputs/checkpoints/
outputs/replay/
outputs/logs/
outputs/tmp/
outputs/metrics/distill*.jsonl
outputs/metrics/v2*.jsonl
outputs/metrics/v3*.jsonl
# Raw (un-split) ONNX export; only the chunked *.onnx.part* files are committed
# so the browser app can stream them under GitHub's 100MB blob limit.
docs/assets/models/**/*.onnx
